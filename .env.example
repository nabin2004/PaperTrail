# ── OpenAI (required for synthesis / ask / report commands) ──────────────────
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=gpt-4o-mini      # any ChatOpenAI-compatible model
# OPENAI_BASE_URL=             # optional; set for OpenRouter or other OpenAI-compatible APIs

# ── OpenRouter (OpenAI-compatible; use your OpenRouter key as OPENAI_API_KEY) ─
# OPENAI_API_KEY=sk-or-v1-...
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_MODEL=openai/gpt-4o-mini   # provider/model slug from openrouter.ai/models

# ── Ollama (optional local LLM alternative) ──────────────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# ── Embedding model (default: all-MiniLM-L6-v2, downloads automatically) ─────
# EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Data directories (defaults shown) ────────────────────────────────────────
# DATA_DIR=data

# ── Scientist mode (pip install -e ".[scientist]") ───────────────────────────
# E2B_API_KEY=
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# SEMANTIC_SCHOLAR_API_KEY=    # optional, higher rate limits
# WANDB_API_KEY=                # optional
# SCIENTIST_BUDGET_USD=30
