# ── OpenAI (required for synthesis / ask / report commands) ──────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini      # any ChatOpenAI-compatible model

# ── Ollama (optional local LLM alternative) ──────────────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# ── Embedding model (default: all-MiniLM-L6-v2, downloads automatically) ─────
# EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Data directories (defaults shown) ────────────────────────────────────────
# DATA_DIR=data
